<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane styleClass="home-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cvserbaada.smartinventory.controller.HomeController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    <children>
        <VBox alignment="CENTER" maxWidth="520.0" spacing="18.0" styleClass="welcome-card">
            <children>
                <StackPane styleClass="welcome-icon-box">
                    <children>
                        <FontIcon iconLiteral="fas-store" iconSize="54" styleClass="welcome-icon" />
                    </children>
                </StackPane>
                <Label text="Welcome to Smart Inventory System" styleClass="welcome-title" wrapText="true" />
                <Label text="CV. SERBA ADA" styleClass="welcome-subtitle" />
            </children>
        </VBox>
    </children>
</StackPane>
