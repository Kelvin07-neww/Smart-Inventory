<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox alignment="CENTER_LEFT" prefHeight="82.0" spacing="14.0" styleClass="app-header" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cvserbaada.smartinventory.controller.HeaderController">
    <padding>
        <Insets bottom="14.0" left="22.0" right="22.0" top="14.0" />
    </padding>
    <children>
        <HBox alignment="CENTER" styleClass="app-logo-box">
            <children>
                <FontIcon iconLiteral="fas-home" iconSize="28" styleClass="app-logo-icon" />
            </children>
        </HBox>
        <VBox alignment="CENTER_LEFT" spacing="2.0" styleClass="app-title-box">
            <children>
                <Label text="SMART INVENTORY &amp; SALES MANAGEMENT SYSTEM" styleClass="app-title" />
                <Label text="CV. SERBA ADA" styleClass="company-title" />
            </children>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER" spacing="8.0" styleClass="header-info-pill time-pill">
            <children>
                <FontIcon iconLiteral="fas-clock" iconSize="16" styleClass="clock-icon" />
                <VBox spacing="1.0">
                    <children>
                        <Label text="Jam" styleClass="header-info-caption" />
                        <Label fx:id="clockLabel" text="--:--:--" styleClass="header-info-value" />
                    </children>
                </VBox>
            </children>
        </HBox>
        <HBox alignment="CENTER" spacing="8.0" styleClass="header-info-pill date-pill">
            <children>
                <FontIcon iconLiteral="fas-calendar-alt" iconSize="15" styleClass="date-icon" />
                <VBox spacing="1.0">
                    <children>
                        <Label text="Tanggal" styleClass="header-info-caption" />
                        <Label fx:id="dateLabel" text="-" styleClass="header-info-value" />
                    </children>
                </VBox>
            </children>
        </HBox>
        <HBox alignment="CENTER" spacing="8.0" styleClass="header-info-pill user-pill">
            <children>
                <FontIcon iconLiteral="fas-user-circle" iconSize="18" styleClass="user-icon" />
                <VBox spacing="1.0">
                    <children>
                        <Label fx:id="userLabel" text="Guest" styleClass="header-user-name" />
                        <Label fx:id="roleLabel" text="Guest" styleClass="header-user-role" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</HBox>
