<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox alignment="CENTER_LEFT" prefHeight="34.0" spacing="14.0" styleClass="status-bar" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cvserbaada.smartinventory.controller.StatusBarController">
    <padding>
        <Insets bottom="6.0" left="18.0" right="18.0" top="6.0" />
    </padding>
    <children>
        <FontIcon iconLiteral="fas-database" iconSize="13" styleClass="status-icon" />
        <Label fx:id="databaseStatusLabel" text="Database: Ready" styleClass="status-label" />
        <Region HBox.hgrow="ALWAYS" />
        <FontIcon iconLiteral="fas-user" iconSize="13" styleClass="status-icon" />
        <Label fx:id="userLabel" text="User: Guest" styleClass="status-label" />
        <FontIcon iconLiteral="fas-code-branch" iconSize="13" styleClass="status-icon" />
        <Label fx:id="versionLabel" text="Version: 1.0-SNAPSHOT" styleClass="status-label" />
    </children>
</HBox>
